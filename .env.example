# ---- Servidor ----
PORT=3000
# Logs: "json" (produção) ou "pretty". Padrão segue o NODE_ENV.
LOG_FORMAT="pretty"
LOG_LEVEL="log"
# Só para rodar a suíte local; não tem efeito em produção.
RATE_LIMIT_DISABLED="false"
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# URL pública desta API — usada para montar links de download (PDF de moradores).
PUBLIC_API_URL="http://localhost:3000"

# ---- Chamadas ----
# Transbordo: quanto cada morador da fila toca antes de passar para o próximo.
# Total da chamada ≈ este valor × nº de moradores da unidade.
RING_STEP_TIMEOUT_MS=20000

# ---- Banco ----
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/interfone?schema=public"

# ---- Auth (sem senha) ----
# Gere segredos fortes: `openssl rand -base64 32`
JWT_ACCESS_SECRET="troque-por-um-segredo-de-32-chars-ou-mais"
JWT_REFRESH_SECRET="troque-por-outro-segredo-de-32-chars-ou-mais"

# ---- Google OAuth (só no app) ----
GOOGLE_CLIENT_ID_IOS="xxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_ID_ANDROID="xxxx.apps.googleusercontent.com"

# ---- E-mail (SMTP) ----
# SMTP puro, sem SDK: trocar de provedor (Resend, Brevo, SES, Mailtrap, servidor
# próprio) é só mudar estas variáveis. Porta 465 = TLS implícito; 587 = STARTTLS.
# O domínio do MAIL_FROM precisa estar verificado no provedor.
MAIL_FROM="contato@rota.com.br"
MAIL_NAME="Rota"
MAIL_HOST="sandbox.smtp.mailtrap.io"
MAIL_PORT="465"
MAIL_USER="170f31b12b3fdc"
MAIL_PASSWORD="0c6a86246c0195"

# ---- LiveKit (mídia A/V) ----
LIVEKIT_API_KEY="APIxxxxxxxx"
LIVEKIT_API_SECRET="secretxxxxxxxx"
LIVEKIT_URL="wss://seu-projeto.livekit.cloud"

# ---- Push (FCM + APNs/VoIP) ----
FCM_PROJECT_ID="interfone-xxxx"
FCM_CLIENT_EMAIL="firebase-adminsdk@interfone-xxxx.iam.gserviceaccount.com"
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
APNS_KEY_ID=""
APNS_TEAM_ID=""

# ---- Storage (avatares) ----
S3_BUCKET="interfone-avatars"
S3_REGION="sa-east-1"
